{
  "config": {
    "flow_title": "{name}",
    "step": {
      "bluetooth_confirm": {
        "description": "Do you want to set up {name}?"
      },
      "user": {
        "data": { "address": "Device" }
      }
    },
    "abort": {
      "not_supported": "This device is not a BlueRetro adapter.",
      "no_devices_found": "No BlueRetro devices found.",
      "already_configured": "Device is already configured."
    }
  },
  "options": {
    "step": {
      "init": {
        "data": {
          "scan_interval": "Polling interval (minutes)",
          "output_ports": "Output ports (multitap)"
        },
        "data_description": {
          "scan_interval": "How often to poll the adapter while it is idle (1–60 minutes).",
          "output_ports": "How many output ports to read and expose (1 for a single controller; raise for multitap, up to 12)."
        }
      }
    }
  },
  "entity": {
    "sensor": {
      "firmware": { "name": "Firmware" },
      "game_id": { "name": "Game ID" },
      "game": { "name": "Game" },
      "config_source": { "name": "Config source" },
      "abi_version": { "name": "ABI version" },
      "bd_address": { "name": "BD address" },
      "firmware_name": { "name": "Firmware name" }
    },
    "binary_sensor": {
      "config_available": { "name": "Config available" }
    },
    "button": {
      "reboot": { "name": "Reboot" },
      "deep_sleep": { "name": "Deep sleep" },
      "factory_reset": { "name": "Factory reset" }
    },
    "select": {
      "controller_mode": { "name": "Controller mode" },
      "accessory": { "name": "Accessory" },
      "controller_mode_port": { "name": "Controller mode (port {port})" },
      "accessory_port": { "name": "Accessory (port {port})" },
      "memory_card_bank": { "name": "Memory card bank" },
      "multitap": { "name": "Multitap" },
      "system": { "name": "System" },
      "inquiry_mode": { "name": "Pairing mode" }
    },
    "update": {
      "firmware": { "name": "Firmware" }
    }
  },
  "services": {
    "list_config_files": {
      "name": "List config files",
      "description": "List the per-GameID config files stored on the adapter.",
      "fields": {
        "device_id": { "name": "Device", "description": "The BlueRetro adapter." }
      }
    },
    "delete_config_file": {
      "name": "Delete config file",
      "description": "Delete a stored per-GameID config file.",
      "fields": {
        "device_id": { "name": "Device", "description": "The BlueRetro adapter." },
        "name": { "name": "File name", "description": "The config file name (raw GameID)." }
      }
    },
    "get_input_mapping": {
      "name": "Get input mapping",
      "description": "Read the advanced input mappings for a config slot.",
      "fields": {
        "device_id": { "name": "Device", "description": "The BlueRetro adapter." },
        "config_id": { "name": "Config slot", "description": "Input config slot index." }
      }
    },
    "set_input_mapping": {
      "name": "Set input mapping",
      "description": "Write advanced input mappings to a config slot.",
      "fields": {
        "device_id": { "name": "Device", "description": "The BlueRetro adapter." },
        "config_id": { "name": "Config slot", "description": "Input config slot index." },
        "mappings": { "name": "Mappings", "description": "List of mapping entries (src, dest, dest_id, max, threshold, deadzone, turbo, scaling, diag_scaling)." }
      }
    }
  }
}
